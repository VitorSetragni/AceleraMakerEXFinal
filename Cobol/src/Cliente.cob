>>SOURCE FORMAT FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. CLIENTE.

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT ARQ-REQ ASSIGN TO "integracao/requisicao.txt"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-RESP ASSIGN TO "integracao/resposta.txt"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-CLIENTES ASSIGN TO "dados/clientes.dat"
        ORGANIZATION IS LINE SEQUENTIAL.

    SELECT ARQ-TEMP ASSIGN TO "dados/clientes.tmp"
        ORGANIZATION IS LINE SEQUENTIAL.

DATA DIVISION.
FILE SECTION.

FD ARQ-REQ.
COPY "REQUISICAO.cpy".

FD ARQ-RESP.
COPY "RESPOSTA.cpy".

FD ARQ-CLIENTES.
COPY "CLIENTE.cpy".

FD ARQ-TEMP.
01 REG-TEMP PIC X(110).

WORKING-STORAGE SECTION.
01 WS-FIM                 PIC X VALUE "N".
01 WS-ENCONTRADO          PIC X VALUE "N".
01 WS-REQ-OK              PIC X VALUE "S".
01 WS-CLIENTE-ATUALIZADO  PIC X(110).
01 WS-COMANDO             PIC X(100)
    VALUE "mv dados/clientes.tmp dados/clientes.dat".

PROCEDURE DIVISION.
INICIO.
    PERFORM LER-REQUISICAO

    IF WS-REQ-OK = "N"
        PERFORM ESCREVER-ERRO
        STOP RUN
    END-IF

    EVALUATE REQ-OPERACAO
        WHEN "C"
            PERFORM CONSULTAR-CLIENTE
        WHEN "A"
            PERFORM ATUALIZAR-CLIENTE
        WHEN OTHER
            PERFORM ESCREVER-ERRO
    END-EVALUATE

    STOP RUN.

LER-REQUISICAO.
    OPEN INPUT ARQ-REQ

    READ ARQ-REQ
        AT END
            MOVE "N" TO WS-REQ-OK
        NOT AT END
            MOVE "S" TO WS-REQ-OK
    END-READ

    CLOSE ARQ-REQ.

CONSULTAR-CLIENTE.
    MOVE "N" TO WS-FIM
    MOVE "N" TO WS-ENCONTRADO

    OPEN INPUT ARQ-CLIENTES

    PERFORM UNTIL WS-FIM = "S"
        READ ARQ-CLIENTES
            AT END
                MOVE "S" TO WS-FIM
            NOT AT END
                IF CLI-CODIGO = REQ-CODIGO
                    MOVE "S" TO WS-ENCONTRADO
                    MOVE "S" TO WS-FIM
                END-IF
        END-READ
    END-PERFORM

    CLOSE ARQ-CLIENTES

    IF WS-ENCONTRADO = "S"
        PERFORM ESCREVER-OK
    ELSE
        PERFORM ESCREVER-NAO-ENCONTRADO
    END-IF.

ATUALIZAR-CLIENTE.
    MOVE "N" TO WS-FIM
    MOVE "N" TO WS-ENCONTRADO
    MOVE SPACES TO WS-CLIENTE-ATUALIZADO

    OPEN INPUT ARQ-CLIENTES
    OPEN OUTPUT ARQ-TEMP

    PERFORM UNTIL WS-FIM = "S"
        READ ARQ-CLIENTES
            AT END
                MOVE "S" TO WS-FIM
            NOT AT END
                IF CLI-CODIGO = REQ-CODIGO
                    MOVE REQ-TELEFONE TO CLI-TELEFONE
                    MOVE REQ-EMAIL TO CLI-EMAIL
                    MOVE REG-CLIENTE TO WS-CLIENTE-ATUALIZADO
                    MOVE "S" TO WS-ENCONTRADO
                END-IF

                WRITE REG-TEMP FROM REG-CLIENTE
        END-READ
    END-PERFORM

    CLOSE ARQ-CLIENTES
    CLOSE ARQ-TEMP

    CALL "SYSTEM" USING WS-COMANDO

    IF WS-ENCONTRADO = "S"
        MOVE WS-CLIENTE-ATUALIZADO TO REG-CLIENTE
        PERFORM ESCREVER-OK
    ELSE
        PERFORM ESCREVER-NAO-ENCONTRADO
    END-IF.

ESCREVER-OK.
    OPEN OUTPUT ARQ-RESP

    MOVE "OK" TO RESP-STATUS
    MOVE CLI-CODIGO TO RESP-CODIGO
    MOVE CLI-NOME TO RESP-NOME
    MOVE CLI-TELEFONE TO RESP-TELEFONE
    MOVE CLI-EMAIL TO RESP-EMAIL

    WRITE REG-RESP

    CLOSE ARQ-RESP.

ESCREVER-NAO-ENCONTRADO.
    OPEN OUTPUT ARQ-RESP

    MOVE "NF" TO RESP-STATUS
    MOVE 0 TO RESP-CODIGO
    MOVE SPACES TO RESP-NOME
    MOVE SPACES TO RESP-TELEFONE
    MOVE SPACES TO RESP-EMAIL

    WRITE REG-RESP

    CLOSE ARQ-RESP.

ESCREVER-ERRO.
    OPEN OUTPUT ARQ-RESP

    MOVE "ER" TO RESP-STATUS
    MOVE 0 TO RESP-CODIGO
    MOVE SPACES TO RESP-NOME
    MOVE SPACES TO RESP-TELEFONE
    MOVE SPACES TO RESP-EMAIL

    WRITE REG-RESP

    CLOSE ARQ-RESP.
    